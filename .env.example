# atproto / standard.site publishing (used by scripts/publish-atproto.js)
# Your handle, e.g. example.com or you.bsky.social
BLUESKY_HANDLE=
# App password from bsky.social -> Settings -> Privacy and security -> App Passwords
# (NOT your account password)
BLUESKY_APP_PASSWORD=
# Optional: override the PDS endpoint if you self-host or are on a different instance (defaults to https://bsky.social)
# BLUESKY_SERVICE=https://eurosky.social
